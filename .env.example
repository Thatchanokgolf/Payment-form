# Copy to .env for local dev (used by `netlify dev`).
# Get this connection string from the Neon dashboard → Connection Details.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Second Neon DB holding the `room` availability table (roomno, status).
# Used by the reservation form to check/claim room availability.
ROOM_DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
